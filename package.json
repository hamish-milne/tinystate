{
  "name": "tinystate",
  "version": "0.1.3",
  "description": "A tiny state management library for React and Preact.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamish-milne/tinystate"
  },
  "author": "Hamish Milne",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.12.0",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@preact/signals": "^2.7.1",
    "@standard-schema/spec": "^1.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "0.27.3",
    "happy-dom": "^20.6.1",
    "preact": "^10.28.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "valibot": "^1.2.0",
    "vite": "^7.3.1",
    "vite-bundle-analyzer": "^1.3.6",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@preact/signals": ">=2.0.0",
    "@standard-schema/spec": ">=1.0.0",
    "preact": ">=10.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@preact/signals": {
      "optional": true
    },
    "@standard-schema/spec": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "resolutions": {
    "@testing-library/dom": "^10.4.1",
    "ansi-styles": "^6.1.0",
    "node-gyp": "npm:empty-npm-package@1.0.0"
  },
  "scripts": {
    "lint": "biome lint",
    "test": "vitest run",
    "bundle": "esbuild --bundle ./src/index.ts --minify --format=esm --external:react --define:import.meta.vitest=undefined --outfile=./dist/index.js --analyze --mangle-props=^_",
    "build_js": "esbuild ./src/*.ts --minify-identifiers --minify-syntax --format=esm --define:import.meta.vitest=undefined --outdir=./dist/ --mangle-props=^_ --sourcemap",
    "build": "rm tsconfig.tsbuildinfo ; tsc & yarn build_js"
  }
}
